# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clé service_role : NE JAMAIS exposer côté client, utilisée uniquement par
# les routes serveur de synchronisation email (cron + sync manuel admin)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- URL publique de l'app (sans slash final) ---
# En local : http://localhost:3000
# En prod  : https://ton-projet.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (Google Cloud Console > APIs & Services > Credentials) ---
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# --- Secret pour sécuriser la route cron ---
# Génère une valeur aléatoire, ex: openssl rand -hex 32
CRON_SECRET=change-moi
